DATABASE_URL=postgres://user@localhost:5432/tutorstar
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000

# Email (transactional). Without RESEND_API_KEY, emails are logged to the
# server console instead of sent — fine for local dev. To send for real, set a
# Resend API key and a verified From address.
RESEND_API_KEY=
EMAIL_FROM=TutorStar <onboarding@resend.dev>
